# Firebase Web SDK config. ALL of these are client-safe — Firestore Security
# Rules (PRJ-805) are the real authz surface. See README "Firebase config is
# public" for context. Real values live in .env.local (gitignored).
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Public host for QR code URLs. Must be short — bundled config rejects
# long values with a dev-time warning.
VITE_PUBLIC_HOST=example.com

# Admin gate (PRJ-856). The email allowed to manage /staff. Compared
# case-insensitively client-side; Firestore /config/admin.adminEmail MUST
# match the lowercased Auth-normalized value. Mirrored via GH Actions var.
VITE_ADMIN_EMAIL=admin@example.com
