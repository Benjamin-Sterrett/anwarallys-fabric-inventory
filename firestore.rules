rules_version = '2';

// DENY-ALL SKELETON — replace with real rules in PRJ-805.
// Every read and write path is explicitly denied until the real Security
// Rules land. This prevents accidental open-by-default behavior while the
// scaffold is deployed.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
